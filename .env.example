# Telegram bot
TELEGRAM_BOT_TOKEN=your-token-here
TELEGRAM_ALLOWED_USER_ID=123456789

# OpenCode
OPENCODE_MODEL=opencode/minimax-m3-free
OPENCODE_HOST=127.0.0.1
OPENCODE_PORT=4096
OPENCODE_SERVER_PASSWORD=change-me-to-a-long-random-string

# Paths
INSTALL_DIR=/root/.opencode-telegram
MEMORY_DIR=/root/.opencode-telegram/memory
DATA_DIR=/root/.opencode-telegram/data

# Misc
TZ=Asia/Kolkata
LOG_LEVEL=INFO
SHELL_TIMEOUT=120
